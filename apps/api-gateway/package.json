{
  "name": "@nebutra/api-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clerk/backend": "^3.0.1",
    "@hono/node-server": "^1.19.11",
    "@hono/swagger-ui": "^0.6.0",
    "@hono/zod-openapi": "^1.2.2",
    "@hono/zod-validator": "^0.7.6",
    "@nebutra/alerting": "workspace:*",
    "@nebutra/cache": "workspace:*",
    "@nebutra/db": "workspace:*",
    "@nebutra/errors": "workspace:*",
    "@nebutra/health": "workspace:*",
    "@nebutra/logger": "workspace:*",
    "@nebutra/rate-limit": "workspace:*",
    "@nebutra/repositories": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "hono": "^4.12.5",
    "inngest": "^3.52.6",
    "stripe": "^20.4.1",
    "svix": "^1.87.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/client": "^7.4.2",
    "@types/node": "^22.19.15",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
