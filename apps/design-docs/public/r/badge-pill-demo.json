{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "badge-pill-demo",
  "type": "registry:example",
  "dependencies": ["@nebutra/icons", "@nebutra/ui"],
  "registryDependencies": ["@nebutra/ui"],
  "files": [
    {
      "path": "registry/examples/badge-pill-demo.tsx",
      "content": "\"use client\";\n\nimport { Badge } from \"@nebutra/ui/primitives\";\nimport { LogoSlackColor } from \"@nebutra/icons\";\nimport Link from \"next/link\";\n\nexport function BadgePillDemo() {\n  return (\n    <div className=\"flex flex-col items-center justify-center gap-4 w-full\">\n      <div className=\"flex flex-row items-center justify-center gap-2 flex-initial\">\n        <Badge asChild size=\"sm\" variant=\"pill\">\n          <Link href=\"#badge-pill\">Label</Link>\n        </Badge>\n        <Badge asChild size=\"md\" variant=\"pill\">\n          <Link href=\"#badge-pill\">Label</Link>\n        </Badge>\n        <Badge asChild size=\"lg\" variant=\"pill\">\n          <Link href=\"#badge-pill\">Label</Link>\n        </Badge>\n      </div>\n      <div className=\"flex flex-row items-center justify-center gap-2 flex-initial\">\n        <Badge\n          asChild\n          icon={<LogoSlackColor />}\n          size=\"sm\"\n          variant=\"pill\"\n        >\n          <Link href=\"#badge-pill\">Label</Link>\n        </Badge>\n        <Badge\n          asChild\n          icon={<LogoSlackColor />}\n          size=\"md\"\n          variant=\"pill\"\n        >\n          <Link href=\"#badge-pill\">Label</Link>\n        </Badge>\n        <Badge\n          asChild\n          icon={<LogoSlackColor />}\n          size=\"lg\"\n          variant=\"pill\"\n        >\n          <Link href=\"#badge-pill\">Label</Link>\n        </Badge>\n      </div>\n    </div>\n  );\n}\n",
      "type": "registry:example"
    }
  ]
}
