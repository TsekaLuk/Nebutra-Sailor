{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "sheet-demo",
  "type": "registry:example",
  "dependencies": ["@nebutra/ui"],
  "registryDependencies": ["@nebutra/ui"],
  "files": [
    {
      "path": "registry/examples/sheet-demo.tsx",
      "content": "\"use client\";\n\nimport {\n  Sheet,\n  SheetTrigger,\n  SheetContent,\n  SheetHeader,\n  SheetTitle,\n  SheetDescription,\n  SheetFooter,\n  SheetClose,\n  Button\n} from \"@nebutra/ui/primitives\";\n\nexport function SheetDemo() {\n  return (\n    <Sheet>\n      <SheetTrigger asChild>\n        <Button variant=\"outline\">Open Sheet</Button>\n      </SheetTrigger>\n      <SheetContent>\n        <SheetHeader>\n          <SheetTitle>Edit profile</SheetTitle>\n          <SheetDescription>Make changes to your profile here. Click save when done.</SheetDescription>\n        </SheetHeader>\n        <div className=\"py-6\">\n          <p className=\"text-sm text-muted-foreground\">Sheet body content.</p>\n        </div>\n        <SheetFooter>\n          <SheetClose asChild>\n            <Button variant=\"outline\">Cancel</Button>\n          </SheetClose>\n          <Button type=\"submit\">Save changes</Button>\n        </SheetFooter>\n      </SheetContent>\n    </Sheet>\n  );\n}\n",
      "type": "registry:example"
    }
  ]
}
