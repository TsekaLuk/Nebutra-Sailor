{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "terminal-demo",
  "type": "registry:example",
  "dependencies": ["@nebutra/ui"],
  "registryDependencies": ["@nebutra/ui"],
  "files": [
    {
      "path": "registry/examples/terminal-demo.tsx",
      "content": "import { Terminal, TypingAnimation, AnimatedSpan } from \"@nebutra/ui/primitives\";\n\nexport function TerminalDemo() {\n    return (\n        <div className=\"w-full max-w-2xl px-4 py-8\">\n            <Terminal>\n                <TypingAnimation>&gt; pnpm install @nebutra/ui</TypingAnimation>\n\n                <AnimatedSpan className=\"text-emerald-500\">\n                    ✔ Packages installed successfully.\n                </AnimatedSpan>\n\n                <TypingAnimation>&gt; nebutra start dev</TypingAnimation>\n\n                <AnimatedSpan className=\"text-blue-400\">\n                    ℹ Starting development server...\n                </AnimatedSpan>\n\n                <AnimatedSpan className=\"text-emerald-500\">\n                    ✔ Ready on http://localhost:3000\n                </AnimatedSpan>\n            </Terminal>\n        </div>\n    )\n}\n",
      "type": "registry:example"
    }
  ]
}
