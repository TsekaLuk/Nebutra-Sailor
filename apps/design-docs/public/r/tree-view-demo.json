{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "tree-view-demo",
  "type": "registry:example",
  "dependencies": ["@nebutra/ui"],
  "registryDependencies": ["@nebutra/ui"],
  "files": [
    {
      "path": "registry/examples/tree-view-demo.tsx",
      "content": "\"use client\";\n\nimport {\n    TreeView,\n    TreeProvider,\n    TreeNode,\n    TreeNodeTrigger,\n    TreeExpander,\n    TreeIcon,\n    TreeLabel,\n    TreeNodeContent\n} from \"@nebutra/ui/primitives\";\n\nexport function TreeViewDemo() {\n    return (\n        <div className=\"w-full max-w-md mx-auto p-4 md:p-8\">\n            <div className=\"rounded-xl border bg-card text-card-foreground shadow-sm overflow-hidden\">\n                <div className=\"p-4 border-b bg-muted/50\">\n                    <h3 className=\"font-semibold text-sm\">Project Structure</h3>\n                </div>\n\n                <div className=\"p-2 h-[400px] overflow-y-auto\">\n                    <TreeProvider defaultExpandedIds={[\"root\", \"src\", \"components\"]}>\n                        <TreeView>\n\n                            <TreeNode nodeId=\"root\">\n                                <TreeNodeTrigger>\n                                    <TreeExpander hasChildren />\n                                    <TreeIcon hasChildren />\n                                    <TreeLabel>nebutra-sailor</TreeLabel>\n                                </TreeNodeTrigger>\n\n                                <TreeNodeContent hasChildren>\n\n                                    <TreeNode nodeId=\"apps\">\n                                        <TreeNodeTrigger>\n                                            <TreeExpander hasChildren />\n                                            <TreeIcon hasChildren />\n                                            <TreeLabel>apps</TreeLabel>\n                                        </TreeNodeTrigger>\n                                        <TreeNodeContent hasChildren>\n                                            <TreeNode nodeId=\"docs\">\n                                                <TreeNodeTrigger>\n                                                    <TreeExpander />\n                                                    <TreeIcon />\n                                                    <TreeLabel>design-docs</TreeLabel>\n                                                </TreeNodeTrigger>\n                                            </TreeNode>\n                                            <TreeNode nodeId=\"web\" isLast>\n                                                <TreeNodeTrigger>\n                                                    <TreeExpander />\n                                                    <TreeIcon />\n                                                    <TreeLabel>web-app</TreeLabel>\n                                                </TreeNodeTrigger>\n                                            </TreeNode>\n                                        </TreeNodeContent>\n                                    </TreeNode>\n\n                                    <TreeNode nodeId=\"packages\">\n                                        <TreeNodeTrigger>\n                                            <TreeExpander hasChildren />\n                                            <TreeIcon hasChildren />\n                                            <TreeLabel>packages</TreeLabel>\n                                        </TreeNodeTrigger>\n                                        <TreeNodeContent hasChildren>\n                                            <TreeNode nodeId=\"ui\">\n                                                <TreeNodeTrigger>\n                                                    <TreeExpander hasChildren />\n                                                    <TreeIcon hasChildren />\n                                                    <TreeLabel>ui</TreeLabel>\n                                                </TreeNodeTrigger>\n                                                <TreeNodeContent hasChildren>\n                                                    <TreeNode nodeId=\"components\">\n                                                        <TreeNodeTrigger>\n                                                            <TreeExpander hasChildren />\n                                                            <TreeIcon hasChildren />\n                                                            <TreeLabel>primitives</TreeLabel>\n                                                        </TreeNodeTrigger>\n                                                        <TreeNodeContent hasChildren>\n                                                            <TreeNode nodeId=\"button\">\n                                                                <TreeNodeTrigger>\n                                                                    <TreeExpander />\n                                                                    <TreeIcon />\n                                                                    <TreeLabel>button.tsx</TreeLabel>\n                                                                </TreeNodeTrigger>\n                                                            </TreeNode>\n                                                            <TreeNode nodeId=\"tree\" isLast>\n                                                                <TreeNodeTrigger>\n                                                                    <TreeExpander />\n                                                                    <TreeIcon />\n                                                                    <TreeLabel>tree.tsx</TreeLabel>\n                                                                </TreeNodeTrigger>\n                                                            </TreeNode>\n                                                        </TreeNodeContent>\n                                                    </TreeNode>\n                                                    <TreeNode nodeId=\"utils\" isLast>\n                                                        <TreeNodeTrigger>\n                                                            <TreeExpander />\n                                                            <TreeIcon />\n                                                            <TreeLabel>utils.ts</TreeLabel>\n                                                        </TreeNodeTrigger>\n                                                    </TreeNode>\n                                                </TreeNodeContent>\n                                            </TreeNode>\n                                        </TreeNodeContent>\n                                    </TreeNode>\n\n                                    <TreeNode nodeId=\"package.json\">\n                                        <TreeNodeTrigger>\n                                            <TreeExpander />\n                                            <TreeIcon />\n                                            <TreeLabel>package.json</TreeLabel>\n                                        </TreeNodeTrigger>\n                                    </TreeNode>\n\n                                    <TreeNode nodeId=\"readme\" isLast>\n                                        <TreeNodeTrigger>\n                                            <TreeExpander />\n                                            <TreeIcon />\n                                            <TreeLabel>README.md</TreeLabel>\n                                        </TreeNodeTrigger>\n                                    </TreeNode>\n\n                                </TreeNodeContent>\n                            </TreeNode>\n\n                        </TreeView>\n                    </TreeProvider>\n                </div>\n            </div>\n        </div>\n    );\n}\n",
      "type": "registry:example"
    }
  ]
}
