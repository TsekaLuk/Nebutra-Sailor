{
  "$schema": "./schemas/ui-governance.schema.json",
  "policyVersion": "2026.03.v1",
  "rawTailwindColorBudgets": [
    {
      "surface": "landing-marketing",
      "root": "apps/landing-page/src",
      "extensions": [".tsx"],
      "excludeContains": ["/(legal)/"],
      "max": 0
    },
    {
      "surface": "web-app",
      "root": "apps/web/src",
      "extensions": [".tsx"],
      "excludeContains": [],
      "max": 0
    }
  ],
  "tokenFormatBudget": {
    "tokenSurfaces": [
      {
        "root": "packages/ui/src/theme",
        "extensions": [".ts", ".tsx"]
      },
      {
        "root": "packages/theme/themes.css",
        "extensions": [".css"]
      }
    ],
    "maxHexLiterals": 9,
    "maxHslLiterals": 1,
    "minOklchLiterals": 120,
    "allowedHexFiles": ["packages/ui/src/theme/tokens.ts"],
    "allowedHslFiles": []
  },
  "motionBoundary": {
    "appSurfaces": ["apps/landing-page/src", "apps/web/src"],
    "allowedFramerMotionImports": [
      "apps/landing-page/src/components/landing/AnimateIn.tsx",
      "packages/ui/src/components/animate-in.tsx"
    ]
  },
  "componentTierCoverage": {
    "primitivesRoot": "packages/ui/src/components",
    "tiers": [
      {
        "name": "tier-1",
        "requiredCoverage": 1,
        "components": [
          "button",
          "input",
          "checkbox-group",
          "combobox",
          "command-menu",
          "dialog",
          "popover",
          "select",
          "tabs",
          "tooltip",
          "skeleton",
          "switch"
        ]
      }
    ]
  },
  "dependencyBoundaries": {
    "appSurfaces": ["apps/landing-page/src", "apps/web/src"],
    "forbiddenImportRegexes": ["^@nebutra\\/[^\\/]+\\/[^\\/]+\\/.+"],
    "customUiAllowedExports": [".", "./components", "./icons", "./theme"]
  },
  "budgets": {
    "rawTailwindColors": {
      "description": "Raw Tailwind color utilities (bg-slate-*, text-gray-*, etc.) — use semantic tokens instead",
      "max": 4,
      "paths": [
        "packages/ui/src/**",
        "apps/web/src/**",
        "apps/landing-page/src/**"
      ],
      "exclude": ["**/*.stories.*", "**/globals.css"]
    },
    "rawTailwindBorderRadius": {
      "description": "Raw Tailwind border-radius utilities — use var(--radius-*) tokens instead",
      "max": 0,
      "paths": [
        "packages/ui/src/**",
        "apps/web/src/**",
        "apps/landing-page/src/**"
      ],
      "exclude": ["**/*.stories.*"]
    }
  }
}
