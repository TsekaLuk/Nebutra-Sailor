{
  "name": "nebutra-sailor",
  "version": "1.7.10",
  "private": true,
  "description": "Enterprise-grade SaaS monorepo for AI-native, multi-tenant platforms",
  "scripts": {
    "dev": "turbo run dev",
    "build": "pnpm brand:sync && turbo run build",
    "build:strict": "pnpm ui:verify-governance && pnpm brand:verify-tokens && pnpm run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:ci": "turbo run test:ci",
    "test:coverage": "turbo run test -- --coverage",
    "test:arch": "vitest run --config vitest.arch.config.ts",
    "check-env": "npx tsx infra/scripts/check-env.ts",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "db:studio": "pnpm --filter @nebutra/db db:studio",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "clean:deps": "knip",
    "brand:sync": "pnpm --filter @nebutra/brand sync",
    "brand:init": "tsx scripts/brand-init.ts",
    "brand:apply": "tsx scripts/brand-apply.ts",
    "brand:palette": "node scripts/generate-palette.mjs",
    "brand:verify-tokens": "tsx scripts/verify-brand-token-sync.ts",
    "ui:validate-policy": "tsx scripts/validate-ui-governance-policy.ts",
    "ui:verify-governance": "pnpm ui:validate-policy && tsx scripts/verify-ui-governance.ts",
    "prepare": "lefthook install",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major",
    "release:patch": "commit-and-tag-version --release-as patch",
    "release:dry": "commit-and-tag-version --dry-run",
    "changelog": "conventional-changelog -p angular -i changelog/CHANGELOG.md -s",
    "changelog:all": "conventional-changelog -p angular -i changelog/CHANGELOG.md -s -r 0",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:ci": "playwright test --reporter=github",
    "dev:ai-saas": "turbo run dev --filter=@nebutra/web --filter=@nebutra/landing-page --filter=@nebutra/api-gateway --filter=@nebutra/studio --filter=@nebutra/admin --filter=@nebutra/design-docs",
    "dev:marketing": "turbo run dev --filter=@nebutra/landing-page --filter=@nebutra/blog --filter=@nebutra/studio",
    "dev:dashboard": "turbo run dev --filter=@nebutra/web --filter=@nebutra/admin --filter=@nebutra/api-gateway",
    "dev:overseas": "turbo run dev --filter=@nebutra/web --filter=@nebutra/landing-page --filter=@nebutra/api-gateway --filter=@nebutra/blog",
    "dev:growth": "turbo run dev --filter=@nebutra/web --filter=@nebutra/landing-page --filter=@nebutra/blog",
    "dev:creative": "turbo run dev --filter=@nebutra/landing-page --filter=@nebutra/blog",
    "dev:blog": "turbo run dev --filter=@nebutra/landing-page --filter=@nebutra/blog",
    "dev:community": "turbo run dev --filter=@nebutra/web --filter=@nebutra/api-gateway --filter=@nebutra/blog",
    "dev:solo": "turbo run dev --filter=@nebutra/web --filter=@nebutra/landing-page --filter=@nebutra/admin --filter=@nebutra/blog",
    "dev:design": "turbo run dev --filter=@nebutra/design-docs --filter=@nebutra/ui",
    "build:ai-saas": "turbo run build --filter=@nebutra/web --filter=@nebutra/landing-page --filter=@nebutra/api-gateway --filter=@nebutra/studio --filter=@nebutra/admin --filter=@nebutra/design-docs",
    "build:marketing": "turbo run build --filter=@nebutra/landing-page --filter=@nebutra/blog --filter=@nebutra/studio",
    "build:dashboard": "turbo run build --filter=@nebutra/web --filter=@nebutra/admin --filter=@nebutra/api-gateway",
    "preset:env": "tsx packages/preset/src/cli.ts",
    "generate:api-types": "tsx scripts/generate-api-types.ts",
    "size": "size-limit",
    "size:why": "size-limit --why"
  },
  "keywords": [
    "saas",
    "monorepo",
    "nextjs",
    "ai",
    "multi-tenant"
  ],
  "author": "Nebutra",
  "license": "AGPL-3.0",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.32.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19",
      "@types/react-dom": "^19",
      "react-avatar-editor": "^14.0.0",
      "baseline-browser-mapping": "^2.10.0",
      "zod": "^4.0.0",
      "fast-xml-parser": ">=5.5.6",
      "body-parser": ">=1.20.3",
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "@hono/node-server": ">=1.19.10",
      "hono": ">=4.12.4",
      "axios": ">=1.13.5",
      "minimatch": ">=9.0.7",
      "glob": ">=10.5.0",
      "rollup": ">=4.59.0",
      "svgo": ">=3.3.3",
      "tar": ">=7.5.11",
      "undici@^6": ">=6.24.0",
      "undici@^7": ">=7.24.0",
      "@actions/http-client>undici": ">=7.24.0",
      "@actions/github>undici": ">=7.24.0",
      "@vercel/blob>undici": ">=7.24.0",
      "@redocly/respect-core>undici": ">=7.24.0",
      "jsdom>undici": ">=7.24.0",
      "path-to-regexp": ">=0.1.12",
      "valibot": ">=1.2.0",
      "next": ">=16.0.11"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "styled-components"
      ],
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    },
    "patchedDependencies": {
      "@clerk/nextjs@7.0.1": "patches/@clerk__nextjs@7.0.1.patch"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@size-limit/preset-small-lib": "^11.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.18.0",
    "@vitejs/plugin-react": "^5.1.4",
    "ajv": "^8.18.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "commit-and-tag-version": "^12.6.1",
    "conventional-changelog-cli": "^5.0.0",
    "fast-check": "^4.5.3",
    "jsdom": "^28.1.0",
    "knip": "^5.88.1",
    "lefthook": "^2.1.4",
    "openapi-typescript": "^7.13.0",
    "size-limit": "^11.2.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "pg": "^8.20.0"
  }
}
