{
  "name": "@nebutra/analytics",
  "version": "0.0.1",
  "private": true,
  "description": "Link attribution, conversion tracking, and product analytics (Dub + PostHog)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.mjs",
      "require": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./server": {
      "import": "./dist/server.mjs",
      "require": "./dist/server.js",
      "types": "./dist/server.d.ts"
    },
    "./posthog": {
      "import": "./dist/posthog.mjs",
      "require": "./dist/posthog.js",
      "types": "./dist/posthog.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dub": "^0.71.5",
    "posthog-js": "^1.360.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "keywords": [
    "analytics",
    "dub",
    "link-tracking",
    "conversion",
    "referral",
    "attribution"
  ],
  "license": "AGPL-3.0"
}
