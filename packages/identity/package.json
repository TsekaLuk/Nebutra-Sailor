{
  "name": "@nebutra/identity",
  "version": "0.1.0",
  "private": true,
  "description": "Provider-agnostic identity adapter layer (Clerk-first, Auth.js-ready)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters/clerk": {
      "import": "./dist/adapters/clerk.js",
      "types": "./dist/adapters/clerk.d.ts"
    },
    "./adapters/authjs": {
      "import": "./dist/adapters/authjs.js",
      "types": "./dist/adapters/authjs.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nebutra/contracts": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
