{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:monorepos",
    "group:recommended",
    ":separateMajorReleases",
    ":automergeMinor",
    ":automergeDigest"
  ],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchPackagePatterns": ["@nebutra/*"],
      "enabled": false
    },
    {
      "matchManagers": ["pip_requirements"],
      "groupName": "python dependencies"
    }
  ]
}
