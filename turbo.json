{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.local", ".env.production", ".env.staging"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "eslint.config*", ".eslintrc*"],
      "env": ["NODE_ENV"]
    },
    "typecheck": {
      "dependsOn": ["^build", "db:generate"],
      "inputs": ["$TURBO_DEFAULT$", "tsconfig*.json"],
      "env": ["NODE_ENV"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "vitest.config*"],
      "outputs": ["coverage/**", "test-results/**"]
    },
    "test:ci": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "vitest.config*"],
      "outputs": ["coverage/**", "test-results/**"],
      "env": ["CI"]
    },
    "test:coverage": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "vitest.config*"],
      "outputs": ["coverage/**"],
      "env": ["CI"]
    },
    "test:watch": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "vitest.config*"],
      "cache": false,
      "persistent": true
    },
    "size": {
      "dependsOn": ["build"],
      "inputs": ["$TURBO_DEFAULT$", ".size-limit.json"],
      "outputs": []
    },
    "db:generate": {
      "cache": true,
      "inputs": ["packages/db/prisma/schema.prisma"],
      "outputs": ["node_modules/.pnpm/@prisma+client*/**"]
    },
    "db:migrate": {
      "cache": false,
      "inputs": ["packages/db/prisma/**"],
      "env": ["DATABASE_URL"]
    },
    "db:push": {
      "cache": false,
      "inputs": ["packages/db/prisma/**"],
      "env": ["DATABASE_URL"]
    },
    "e2e": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
